# Multi-platform Docker build for custom-protocol
FROM golang:1.21-alpine AS builder

WORKDIR /app
COPY . .
RUN go build -o customproto .

FROM alpine:latest
COPY --from=builder /app/customproto /usr/local/bin/
COPY docker-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["server"]